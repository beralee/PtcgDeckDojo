static func t(key: String, params: Dictionary = {}) -> String:
	var template := str(STRINGS.get(key, key))
	if params.is_empty():
		return template

	var rendered := template
	for param_key_variant: Variant in params.keys():
		var param_key := str(param_key_variant)
		rendered = rendered.replace("{%s}" % param_key, str(params.get(param_key_variant, "")))
	return rendered
