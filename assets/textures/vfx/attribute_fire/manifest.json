{
  "package_id": "attribute_fire_ember_burst",
  "attribute": "fire",
  "visual_rule": "Fire should read as one hot combustion subject: a white-yellow ignition core, orange-red flame body, ember sparks, and a restrained smoke tail. The impact bloom is the hero; the travel streak is only a readable connector. Keep the effect premium and battle-clear, not beam-heavy, not fireworks, and not a fog wall.",
  "playback_model": "cast + travel + impact",
  "anchor_policy": "Use center anchors when a precise emit point is unavailable.",
  "suppressed_layers": [
    "generic laser beams",
    "electric arcs",
    "glitter fireworks",
    "full-screen fog",
    "decorative rings",
    "hard-edged rectangles"
  ],
  "palette": {
    "core": "#FFF6D5",
    "flame": "#FF9A2F",
    "ember": "#FF4D1F",
    "smoke": "#39201D",
    "highlight": "#FFF1A6"
  },
